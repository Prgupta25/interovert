PORT=5001

# Where the React app is reachable in the BROWSER (used for password-reset links in emails).
# localhost only works on the same computer — phones cannot open it.
#
# Production: your real site
#   FRONTEND_URL=https://your-app.vercel.app
# Same Wi‑Fi phone testing: your PC’s LAN IP + Vite with --host
#   FRONTEND_URL=http://192.168.1.10:5173
# Optional: links in emails only (overrides FRONTEND_URL for those links if set)
#   PUBLIC_APP_URL=https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
PUBLIC_APP_URL=

MONGODB_URI=mongodb://127.0.0.1:27017/interovert
JWT_SECRET=replace_with_strong_secret

# SMTP (nodemailer); optional if using Resend only
EMAIL_USER=your_smtp_user@example.com
EMAIL_PASS=your_app_password

RESEND_API_KEY=re_xxxx
EMAIL_FROM=Introvert <onboarding@resend.dev>

# PostgreSQL (for /api/community module)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=interovert
PG_SSL=false

GEMINI_API_KEY=
OPENAI_API_KEY=

# Google Dialogflow ES (optional — /api/chat tries this first when project + credentials are set)
DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_LANGUAGE_CODE=en
GOOGLE_APPLICATION_CREDENTIALS=dialogflow-sa.json
# Or one-line JSON in .env (private_key newlines as \n), instead of a file:
GOOGLE_SERVICE_ACCOUNT_JSON=

# Elasticsearch (optional – events search)
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=

# Cloudinary (optional – image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp (Twilio) integration
ENABLE_WHATSAPP_NOTIFICATIONS=false
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

WHATSAPP_GROUP_WEBHOOK_URL=http://localhost:5001/api/webhooks/whatsapp-group-create
WHATSAPP_GROUP_WEBHOOK_TOKEN=change_this_token
